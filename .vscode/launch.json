{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "1. Run VoiceType",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet run --project VoiceType.WinUI/VoiceType.WinUI.csproj -c Debug -p:GpuArch=CPU",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "2. Run + Telemetry",
            "type": "node-terminal",
            "request": "launch",
            "command": "$env:ASPNETCORE_ENVIRONMENT='Development'; dotnet run --project VoiceType.WinUI/VoiceType.WinUI.csproj -c Debug -p:GpuArch=CPU",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "3. Run + Aspire Dashboard",
            "type": "node-terminal",
            "request": "launch",
            "command": "$env:ASPNETCORE_ENVIRONMENT='Development'; $env:OTEL_EXPORTER_OTLP_ENDPOINT='http://localhost:4317'; dotnet run --project VoiceType.WinUI/VoiceType.WinUI.csproj -c Debug -p:GpuArch=CPU",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "4. Attach Debugger",
            "type": "coreclr",
            "request": "attach",
            "processName": "VoiceType.WinUI.exe",
            "requireExactSource": false
        }
    ]
}