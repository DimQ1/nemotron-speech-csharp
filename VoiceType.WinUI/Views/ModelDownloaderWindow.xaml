<Window
    x:Class="VoiceType.WinUI.Views.ModelDownloaderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:VoiceType.WinUI.ViewModels"
    Title="Model Downloader">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop/>
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40" Background="{StaticResource BgSecondaryBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="16,0,0,0">
                <FontIcon Glyph="&#xE896;" FontSize="16" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Model downloader" Foreground="{StaticResource FgBrush}"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Model Selection -->
        <Border Grid.Row="1" Background="{StaticResource BgSecondaryBrush}" CornerRadius="4" Padding="10" Margin="12,8,12,8">
            <StackPanel>
                <TextBlock Text="Select Model" Foreground="{StaticResource FgBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.ModelOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}"
                          DisplayMemberPath="Display"
                          Style="{StaticResource DarkComboBox}" Margin="0,0,0,6"
                          IsEnabled="{x:Bind ViewModel.IsIdle, Mode=OneWay}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{x:Bind ViewModel.ModelsRootPath, Mode=TwoWay}"
                             Style="{StaticResource DarkTextBox}" FontSize="11"/>
                    <Button Grid.Column="1" Content="..." Margin="6,0,0,0"
                            Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource FgBrush}"
                            BorderThickness="0" Padding="8,4" FontSize="12" FontWeight="Bold"
                            Command="{x:Bind ViewModel.BrowseRootCommand}"
                            ToolTipService.ToolTip="Browse download folder"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- File Progress -->
        <StackPanel Grid.Row="2" Margin="12,0,12,4">
            <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.CurrentFile, Mode=OneWay}" Foreground="{StaticResource FgSecondaryBrush}"
                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <TextBlock Text="{x:Bind ViewModel.FileProgressDisplay, Mode=OneWay}"
                               Foreground="{StaticResource FgSecondaryBrush}" FontSize="11"/>
                    <TextBlock Text="{x:Bind ViewModel.FileRemaining, Mode=OneWay}"
                               Foreground="{StaticResource FgSecondaryBrush}" FontSize="11" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
            <ProgressBar Height="6" Value="{x:Bind ViewModel.FileProgress, Mode=OneWay}" Minimum="0" Maximum="100"
                         Foreground="{StaticResource AccentBrush}" Background="{StaticResource BgTertiaryBrush}"/>
        </StackPanel>

        <!-- Total Progress -->
        <StackPanel Grid.Row="3" Margin="12,0,12,8">
            <Grid Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Files: " Foreground="{StaticResource FgBrush}" FontSize="11"/>
                    <TextBlock Text="{x:Bind ViewModel.DownloadedFiles, Mode=OneWay}" Foreground="{StaticResource FgBrush}" FontSize="11"/>
                    <TextBlock Text="/" Foreground="{StaticResource FgBrush}" FontSize="11"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalFiles, Mode=OneWay}" Foreground="{StaticResource FgBrush}" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <TextBlock Text="{x:Bind ViewModel.DownloadProgressDisplay, Mode=OneWay}"
                               Foreground="{StaticResource FgBrush}" FontSize="11"/>
                    <TextBlock Text="{x:Bind ViewModel.FolderRemaining, Mode=OneWay}"
                               Foreground="{StaticResource GreenBrush}" FontSize="11" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
            <ProgressBar Height="6" Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}" Minimum="0" Maximum="100"
                         Foreground="{StaticResource GreenBrush}" Background="{StaticResource BgTertiaryBrush}"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="4" Text="{x:Bind ViewModel.Status, Mode=OneWay}" Foreground="{StaticResource FgSecondaryBrush}"
                   FontSize="11" Margin="12,0,12,4" TextWrapping="Wrap"/>

        <Grid Grid.Row="5"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,4">
            <Button Content="Cancel" Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource FgBrush}"
                    BorderThickness="0" Padding="12,6" Margin="0,0,6,0" FontSize="12"
                    Command="{x:Bind ViewModel.CancelCommand}"
                    Visibility="{x:Bind ViewModel.IsDownloading, Mode=OneWay}"/>
            <Button Content="Download &amp; Install" Style="{StaticResource PrimaryButton}" Padding="16,6" FontSize="12"
                    Command="{x:Bind ViewModel.DownloadCommand}"
                    Visibility="{x:Bind ViewModel.IsIdle, Mode=OneWay}"/>
        </StackPanel>
    </Grid>
</Window>
