<Window
    x:Class="VoiceType.WinUI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:VoiceType.WinUI.ViewModels"
    Title="VoiceType">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop/>
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom Title bar (replaces system title bar) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="{StaticResource BgSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="🎙 VoiceType" Foreground="{StaticResource FgBrush}"
                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0">
                <Button Content="&#xE896;" Style="{StaticResource IconButton}"
                        ToolTipService.ToolTip="Download Models"
                        Command="{x:Bind ViewModel.OpenModelDownloaderCommand}"/>
                <Button Content="&#xE713;" Style="{StaticResource IconButton}"
                        ToolTipService.ToolTip="Settings"
                        Command="{x:Bind ViewModel.OpenSettingsCommand}"/>
                <Button Content="&#xE921;" Style="{StaticResource IconButton}"
                        Click="MinimizeButton_Click" ToolTipService.ToolTip="Minimize"/>
                <Button Content="&#xE8BB;" Style="{StaticResource IconButton}"
                        Click="CloseButton_Click" ToolTipService.ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- Model warning banner -->
        <Border Grid.Row="1" Background="{StaticResource RedBrush}" Padding="14,8"
                Visibility="{x:Bind ViewModel.ShowModelWarning, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{x:Bind ViewModel.ModelStatusText, Mode=OneWay}"
                               Foreground="White" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Text="Recommended: CPU (INT4, opset24, 0.56s) — fast, low latency, ~749 MB"
                               Foreground="#FFCCCC" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Download"
                        Background="White" Foreground="{StaticResource RedBrush}"
                        BorderThickness="0" Padding="12,6" FontSize="12" FontWeight="SemiBold"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        Command="{x:Bind ViewModel.OpenModelDownloaderCommand}"/>
                <Button Grid.Column="2" Content="✕"
                        Background="Transparent" Foreground="White"
                        BorderThickness="0" Padding="8,4" FontSize="12"
                        VerticalAlignment="Center" Margin="4,0,0,0"
                        Click="DismissModelWarning_Click"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgSecondaryBrush}" Padding="14,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,8,0"
                             Fill="{StaticResource FgSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Foreground="{StaticResource FgSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.RecordingIndicator, Mode=OneWay}" HorizontalAlignment="Right"
                           Foreground="{StaticResource FgSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Text area -->
        <ScrollViewer x:Name="TextScroller" Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="14,10">
            <TextBox x:Name="TextDisplay"
                     Text="{x:Bind ViewModel.FloatingText, Mode=OneWay}"
                     Foreground="{StaticResource FgBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="15"
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     AcceptsReturn="True"/>
        </ScrollViewer>

        <!-- Bottom controls -->
        <Border Grid.Row="4" Background="{StaticResource BgSecondaryBrush}"
                Padding="14,12">
            <StackPanel>
                <Button Content="{x:Bind ViewModel.RecordButtonText, Mode=OneWay}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{x:Bind ViewModel.ToggleCommand}"
                        HorizontalAlignment="Stretch" Height="42"/>
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontSize="11"
                               Foreground="{StaticResource FgSecondaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Text="Ctrl+Shift+V toggle • Ctrl+Shift+I text injection • Any key/mouse stops"/>

                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  Content="Enable text injection"
                                  IsChecked="{x:Bind ViewModel.IsTextInjectionEnabled, Mode=TwoWay}"
                                  Style="{StaticResource DarkCheckBox}"
                                  VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="&#xE8C8;"
                                FontFamily="Segoe MDL2 Assets"
                                Margin="12,0,0,0"
                                Background="{StaticResource BgTertiaryBrush}"
                                Foreground="{StaticResource FgBrush}"
                                BorderThickness="0"
                                Padding="10,4"
                                FontSize="14"
                                ToolTipService.ToolTip="Copy text"
                                Command="{x:Bind ViewModel.CopyCommand}"/>
                    </Grid>

                    <CheckBox Grid.Row="2"
                              Content="Auto-scroll"
                              Margin="0,4,0,0"
                              IsChecked="{x:Bind ViewModel.IsAutoScrollEnabled, Mode=TwoWay}"
                              Style="{StaticResource DarkCheckBox}"
                              VerticalAlignment="Center"/>

                    <CheckBox Grid.Row="3"
                              Content="Pause injection on focus change"
                              Margin="0,4,0,0"
                              IsChecked="{x:Bind ViewModel.DisableInjectionOnFocusChange, Mode=TwoWay}"
                              Style="{StaticResource DarkCheckBox}"
                              VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
