<Window x:Class="VoiceType.Views.BatchAudioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Audio Transcription"
        Width="1100" Height="700"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BgBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="265"/>   <!-- Files + Settings, fixed -->
            <RowDefinition Height="Auto"/>   <!-- Progress -->
            <RowDefinition Height="Auto"/>   <!-- Action buttons -->
            <RowDefinition Height="Auto"/>   <!-- Player + tabs header -->
            <RowDefinition Height="*" MinHeight="80"/>  <!-- Transcript, fills bottom -->
            <RowDefinition Height="Auto"/>   <!-- Close -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- Row 0: Files + Settings (fixed 265px)           -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: File List ── -->
            <GroupBox Grid.Column="0" Header="Audio Files" Style="{StaticResource DarkGroupBox}"
                      Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Buttons TOP -->
                        <RowDefinition Height="Auto"/>   <!-- File count -->
                        <RowDefinition Height="*"/>       <!-- Scrollable list -->
                    </Grid.RowDefinitions>

                    <!-- Action buttons pinned at TOP -->
                    <Border Grid.Row="0" Padding="0,0,0,4"
                            BorderBrush="{StaticResource BgTertiaryBrush}" BorderThickness="0,0,0,1"
                            Margin="0,0,0,4">
                        <WrapPanel>
                            <Button Content="+ Add Files" Command="{Binding AddFilesCommand}"
                                    Style="{StaticResource DarkButton}" FontSize="12" Padding="8,4" Margin="0,0,4,2"/>
                            <Button Content="+ Add Folder" Command="{Binding AddFolderCommand}"
                                    Style="{StaticResource DarkButton}" FontSize="12" Padding="8,4" Margin="0,0,4,2"/>
                            <Button Content="Remove" Command="{Binding RemoveSelectedCommand}"
                                    Style="{StaticResource DarkButton}" FontSize="12" Padding="8,4" Margin="0,0,4,2"/>
                            <Button Content="Clear All" Command="{Binding ClearAllCommand}"
                                    Style="{StaticResource DarkButton}" FontSize="12" Padding="8,4" Margin="0,0,4,2"/>
                        </WrapPanel>
                    </Border>

                    <!-- File count -->
                    <TextBlock Grid.Row="1" Margin="2,0,0,4" FontSize="11"
                               Foreground="{StaticResource FgSecondaryBrush}"
                               Text="{Binding FileCountSummary, Mode=OneWay}"/>

                    <!-- Scrollable file list -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Files}"
                             SelectedItem="{Binding SelectedJob}"
                             Background="{StaticResource BgSecondaryBrush}"
                             Foreground="{StaticResource FgBrush}"
                             BorderBrush="{StaticResource BgTertiaryBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             MouseDoubleClick="FilesListBox_MouseDoubleClick"
                             KeyDown="FilesListBox_KeyDown">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Files..." Click="AddFiles_Click"/>
                                <MenuItem Header="Add Folder..." Click="AddFolder_Click"/>
                                <Separator/>
                                <MenuItem Header="Remove Selected" Click="RemoveSelected_Click"/>
                                <MenuItem Header="Clear All" Click="ClearAll_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="26" Margin="2,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource FgBrush}" FontSize="12"
                                               ToolTip="{Binding ErrorMessage}" ToolTipService.ShowOnDisabled="True"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}" VerticalAlignment="Center"
                                               Margin="8,0" Foreground="{StaticResource FgSecondaryBrush}" FontSize="11"/>
                                    <TextBlock Grid.Column="3" Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                                               VerticalAlignment="Center" Margin="8,0"
                                               Foreground="{StaticResource FgSecondaryBrush}" FontSize="10"
                                               Visibility="{Binding ProgressPercent, Converter={StaticResource PercentToVisibility}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>

            <!-- ── RIGHT: Settings ── -->
            <GroupBox Grid.Column="2" Header="Settings" Style="{StaticResource DarkGroupBox}" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,2,0">
                        <TextBlock Text="ASR Model" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding AvailableAsrModels}" SelectedIndex="{Binding SelectedAsrModelIndex}"
                                  Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"/>

                        <TextBlock Text="Language" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <ComboBox IsEditable="True" Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                            <ComboBoxItem Content="auto"/><ComboBoxItem Content="en"/><ComboBoxItem Content="ru"/>
                            <ComboBoxItem Content="de"/><ComboBoxItem Content="fr"/><ComboBoxItem Content="es"/>
                            <ComboBoxItem Content="zh"/><ComboBoxItem Content="ja"/><ComboBoxItem Content="ko"/>
                            <ComboBoxItem Content="pt"/><ComboBoxItem Content="it"/>
                        </ComboBox>

                        <CheckBox Content="Enable speaker diarization" IsChecked="{Binding EnableDiarization}"
                                  Style="{StaticResource DarkCheckBox}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding DiarizationModelPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}" FontSize="11" IsEnabled="{Binding EnableDiarization}"/>
                            <Button Grid.Column="1" Content="..." Margin="6,0,0,0" Style="{StaticResource DarkButton}"
                                    Padding="8,4" FontSize="13" FontWeight="Bold"
                                    Command="{Binding BrowseDiarizationModelCommand}" IsEnabled="{Binding EnableDiarization}"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Parallel jobs:" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding Parallelism, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"
                                     Width="36" TextAlignment="Center" FontSize="13"/>
                            <TextBlock Grid.Column="2" Text="(1 - 8)" Foreground="{StaticResource FgSecondaryBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Output directory" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" FontSize="11"/>
                            <Button Grid.Column="1" Content="..." Margin="6,0,0,0" Style="{StaticResource DarkButton}"
                                    Padding="8,4" FontSize="13" FontWeight="Bold" Command="{Binding BrowseOutputDirCommand}"/>
                        </Grid>

                        <TextBlock Text="Export format" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <ComboBox SelectedValue="{Binding ExportFormat}" SelectedValuePath="Content" Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                            <ComboBoxItem Content="txt"/><ComboBoxItem Content="srt"/><ComboBoxItem Content="vtt"/>
                        </ComboBox>

                        <Border Height="8"/>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- Row 1: Progress                                 -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="0,2,0,4" Padding="8,5" CornerRadius="3"
                Background="{StaticResource BgSecondaryBrush}" Visibility="{Binding ProgressVisibility}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ProgressSummary}" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding TotalProgressPercent, StringFormat={}{0}%}"
                               Foreground="{StaticResource FgBrush}" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0"/>
                </Grid>
                <ProgressBar Height="6" Margin="0,5,0,0" Minimum="0" Maximum="100"
                             Value="{Binding TotalProgressPercent, Mode=OneWay}"
                             Foreground="{StaticResource AccentBrush}" Background="{StaticResource BgTertiaryBrush}" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- Row 2: Action Buttons                           -->
        <!-- ═══════════════════════════════════════════════ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2,0,6">
            <Button Content="Start Batch" Style="{StaticResource PrimaryButton}" Command="{Binding StartBatchCommand}" Margin="0,0,8,0"/>
            <Button Content="Cancel" Style="{StaticResource DarkButton}" Command="{Binding CancelBatchCommand}" Margin="0,0,8,0"
                    Visibility="{Binding CancelVisible, Converter={StaticResource BoolToVis}}"/>
            <Button Content="Open Output Folder" Style="{StaticResource DarkButton}" Command="{Binding OpenOutputDirCommand}"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- Row 3: Player + Tabs (attached to bottom area)  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="3" Visibility="{Binding IsViewerVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Playback bar -->
                <Grid Height="30" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="65"/><ColumnDefinition Width="*"/><ColumnDefinition Width="65"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{Binding PlayPauseText, Mode=OneWay}" Style="{StaticResource DarkButton}"
                            Command="{Binding PlayPauseCommand}" Width="30" Height="30" FontSize="13"
                            Padding="0" ToolTip="{Binding PlayPauseTooltip}"/>
                    <Button Grid.Column="1" Content="■" Style="{StaticResource DarkButton}" Command="{Binding StopPlaybackCommand}"
                            Width="28" Height="28" FontSize="11" Padding="0" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding PlaybackPositionText, Mode=OneWay}" Foreground="{StaticResource FgSecondaryBrush}"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0"/>
                    <Slider Grid.Column="3" Minimum="0" Maximum="1" Value="{Binding PlaybackProgress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{x:Null}" VerticalAlignment="Center" IsMoveToPointEnabled="True"/>
                    <TextBlock Grid.Column="4" Text="{Binding PlaybackDurationText, Mode=OneWay}" Foreground="{StaticResource FgSecondaryBrush}"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0,0,0"/>
                </Grid>

                <!-- Tabs + filename header -->
                <Border Padding="0,3,0,4" BorderBrush="{StaticResource BgTertiaryBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ViewerFileName}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource FgBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Plain Text" Style="{StaticResource DarkButton}" FontSize="11" Padding="8,3" Click="SwitchToPlainTab"/>
                            <Button Content="Word Timings" Style="{StaticResource DarkButton}" FontSize="11" Padding="8,3" Click="SwitchToWordsTab" Margin="3,0,0,0"/>
                            <Button Content="Speakers" Style="{StaticResource DarkButton}" FontSize="11" Padding="8,3" Click="SwitchToSpeakersTab" Margin="3,0,0,0"/>
                            <Button Content="✕" Style="{StaticResource DarkButton}" FontSize="11" Padding="6,3" Margin="8,0,0,0"
                                    Click="CloseViewer_Click" ToolTip="Close transcript viewer"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- Row 4: Transcript Content (fills bottom)        -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="4" Margin="0,2,0,0" Visibility="{Binding IsViewerVisible, Converter={StaticResource BoolToVis}}">
            <TextBox Text="{Binding PlainTextView, Mode=OneWay}" Style="{StaticResource DarkTextBox}"
                     TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     Visibility="{Binding SelectedTab, Converter={StaticResource IntEqualsVisibility}, ConverterParameter=0}"/>
            <TextBox Text="{Binding WordTimingsView, Mode=OneWay}" Style="{StaticResource DarkTextBox}"
                     TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="12"
                     Visibility="{Binding SelectedTab, Converter={StaticResource IntEqualsVisibility}, ConverterParameter=1}"/>
            <TextBox Text="{Binding SpeakerView, Mode=OneWay}" Style="{StaticResource DarkTextBox}"
                     TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     Visibility="{Binding SelectedTab, Converter={StaticResource IntEqualsVisibility}, ConverterParameter=2}"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- Row 5: Close button                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="Close" Style="{StaticResource PrimaryButton}" Click="CloseButton_Click" Padding="20,7"/>
        </StackPanel>
    </Grid>
</Window>
