<Window x:Class="VoiceType.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceType Settings"
        Width="560" Height="680"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,16">
                <!-- ── Engine ── -->
                <GroupBox Header="Speech Engine" Style="{StaticResource DarkGroupBox}">
                    <StackPanel>
                        <TextBlock Text="Models Root Folder" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ModelsRootPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"/>
                            <Button Grid.Column="1" Content="..." Margin="8,0,0,0"
                                    Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource FgBrush}"
                                    BorderThickness="0" Padding="10,6" FontSize="13" Cursor="Hand" FontWeight="Bold"
                                    Command="{Binding BrowseRootCommand}"
                                    ToolTip="Browse for models root folder"/>
                        </Grid>

                        <TextBlock Text="Model" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding AvailableModels}"
                                      SelectedItem="{Binding SelectedModel}"
                                      Style="{StaticResource DarkComboBox}"/>
                            <Button Grid.Column="1" Content="Download..." Margin="8,0,0,0"
                                    Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource FgBrush}"
                                    BorderThickness="0" Padding="12,6" FontSize="12" Cursor="Hand"
                                    Command="{Binding OpenModelDownloaderCommand}"/>
                        </Grid>

                        <TextBlock Text="{Binding ModelPath, StringFormat='Full path: {0}'}" 
                                   Foreground="{StaticResource FgSecondaryBrush}" FontSize="10" 
                                   Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="Execution Provider" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <ComboBox SelectedValue="{Binding ExecutionProvider}" SelectedValuePath="Content"
                                  Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                            <ComboBoxItem Content="cpu"/> <ComboBoxItem Content="cuda"/>
                            <ComboBoxItem Content="dml"/> <ComboBoxItem Content="follow_config"/>
                        </ComboBox>

                        <TextBlock Text="Language (BCP-47 code or 'auto')" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <ComboBox IsEditable="True"
                                  Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                            <ComboBoxItem Content="auto"/>
                            <ComboBoxItem Content="en"/>
                            <ComboBoxItem Content="ru"/>
                            <ComboBoxItem Content="de"/>
                            <ComboBoxItem Content="fr"/>
                            <ComboBoxItem Content="es"/>
                            <ComboBoxItem Content="zh"/>
                            <ComboBoxItem Content="ja"/>
                            <ComboBoxItem Content="ko"/>
                            <ComboBoxItem Content="pt"/>
                            <ComboBoxItem Content="it"/>
                            <ComboBoxItem Content="ar"/>
                            <ComboBoxItem Content="hi"/>
                            <ComboBoxItem Content="tr"/>
                            <ComboBoxItem Content="uk"/>
                            <ComboBoxItem Content="pl"/>
                            <ComboBoxItem Content="nl"/>
                        </ComboBox>

                        <CheckBox Content="Use Voice Activity Detection (VAD)"
                                  IsChecked="{Binding UseVad}" Style="{StaticResource DarkCheckBox}"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Capture ── -->
                <GroupBox Header="Audio Capture" Style="{StaticResource DarkGroupBox}">
                    <StackPanel>
                        <TextBlock Text="Audio Source" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <ComboBox SelectedValue="{Binding AudioSource}" SelectedValuePath="Content"
                                  Style="{StaticResource DarkComboBox}">
                            <ComboBoxItem Content="Mic"/> <ComboBoxItem Content="Loopback"/> <ComboBoxItem Content="Mix"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>

                <!-- ── Text Injection ── -->
                <GroupBox Header="Text Injection" Style="{StaticResource DarkGroupBox}">
                    <StackPanel>
                        <TextBlock Text="Injection Method" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <ComboBox SelectedValue="{Binding TextInjectionMethod}" SelectedValuePath="Content"
                                  Style="{StaticResource DarkComboBox}" Margin="0,0,0,8">
                            <ComboBoxItem Content="InputSimulator"/> <ComboBoxItem Content="SendInput"/> <ComboBoxItem Content="Clipboard"/>
                        </ComboBox>
                        <CheckBox Content="Stop recognition on any keyboard/mouse input"
                                  IsChecked="{Binding StopOnAnyInput}" Style="{StaticResource DarkCheckBox}"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Sessions ── -->
                <GroupBox Header="Session Recording" Style="{StaticResource DarkGroupBox}">
                    <StackPanel>
                        <CheckBox Content="Save recognition sessions"
                                  IsChecked="{Binding SaveSessions}" Style="{StaticResource DarkCheckBox}" Margin="0,0,0,6"/>
                        <TextBlock Text="Sessions Path" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding SessionsPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,6"/>
                        <CheckBox Content="Save audio as MP3"
                                  IsChecked="{Binding SaveAudioMp3}" Style="{StaticResource DarkCheckBox}"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Hotkeys ── -->
                <GroupBox Header="Global Hotkeys" Style="{StaticResource DarkGroupBox}">
                    <StackPanel>
                        <TextBlock Text="Toggle Recognition (Ctrl+Shift+V, Ctrl+Alt+R, etc.)"
                                   Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding ToggleHotkey, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>
                        <TextBlock Text="Toggle Mute (Ctrl+Shift+M, Ctrl+Alt+M, etc.)"
                                   Foreground="{StaticResource FgSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MuteHotkey, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>
                </GroupBox>

                <!-- ── Post-processing ── -->
                <GroupBox Header="Post-Processing Pipeline" Style="{StaticResource DarkGroupBox}">
                    <StackPanel>
                        <CheckBox Content="Enable post-processing"
                                  IsChecked="{Binding PostProcessingEnabled}" Style="{StaticResource DarkCheckBox}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Rules" Foreground="{StaticResource FgSecondaryBrush}" FontSize="12"/>
                            <Button Content="+ Add Rule" HorizontalAlignment="Right"
                                    Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource FgBrush}"
                                    BorderThickness="0" Padding="8,3" FontSize="11" Cursor="Hand"
                                    Command="{Binding AddRuleCommand}"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Rules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgSecondaryBrush}"
                                            CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Rule name (editable) + delete -->
                                            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}"
                                                          VerticalAlignment="Center" Margin="0,0,6,0"
                                                          Foreground="{StaticResource FgBrush}"/>

                                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DarkTextBox}" FontSize="12"
                                                         FontWeight="SemiBold"
                                                         VerticalAlignment="Center"/>

                                                <Button Grid.Column="2" Content="✕"
                                                        Background="Transparent" Foreground="{StaticResource RedBrush}"
                                                        BorderThickness="0" Width="24" Height="24" FontSize="12" Cursor="Hand"
                                                        Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>

                                            <!-- Pattern → Replacement -->
                                            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DarkTextBox}" FontSize="11"
                                                         Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource FgSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="4,0"/>
                                                <TextBox Grid.Column="2" Text="{Binding Replacement, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DarkTextBox}" FontSize="11"
                                                         Margin="4,0,0,0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource FgBrush}"
                    BorderThickness="0" Padding="16,8" Cursor="Hand" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"/>
            <Button Content="Save" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</Window>
