<Window x:Class="VoiceType.Views.ModelDownloaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VoiceType.ViewModels"
        Title="Model Downloader"
        Width="520" Height="380"
        MinWidth="440" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BgBrush}">

    <Window.DataContext>
        <vm:ModelDownloaderViewModel/>
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Model Selection -->
        <GroupBox Grid.Row="0" Header="Select Model" Style="{StaticResource DarkGroupBox}" Margin="0,0,0,8">
            <StackPanel>
                <ComboBox ItemsSource="{Binding Source={x:Static vm:ModelDownloaderViewModel.AvailableModels}}"
                          SelectedItem="{Binding SelectedModel}"
                          DisplayMemberPath="Display"
                          Style="{StaticResource DarkComboBox}" Margin="0,0,0,8"
                          IsEnabled="{Binding IsIdle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ModelsRootPath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" FontSize="11"/>
                    <Button Grid.Column="1" Content="..." Margin="8,0,0,0"
                            Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource FgBrush}"
                            BorderThickness="0" Padding="10,6" FontSize="13" Cursor="Hand" FontWeight="Bold"
                            Command="{Binding BrowseRootCommand}"
                            ToolTip="Browse download folder"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- File Progress -->
        <StackPanel Grid.Row="1" Margin="0,0,0,4">
            <Grid Margin="0,0,0,2">
                <TextBlock Text="{Binding CurrentFile}" Foreground="{StaticResource FgSecondaryBrush}"
                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding FileProgressDisplay}"
                               Foreground="{StaticResource FgSecondaryBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding FileRemaining}"
                               Foreground="{StaticResource FgSecondaryBrush}" FontSize="11" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
            <ProgressBar Height="8" Value="{Binding FileProgress}" Minimum="0" Maximum="100"
                         Foreground="{StaticResource AccentBrush}" Background="{StaticResource BgTertiaryBrush}"/>
        </StackPanel>

        <!-- Total Progress -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Grid Margin="0,0,0,2">
                <TextBlock Foreground="{StaticResource FgBrush}" FontSize="11">
                    <Run Text="Files: "/>
                    <Run Text="{Binding DownloadedFiles, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding TotalFiles, Mode=OneWay}"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding DownloadProgressDisplay}"
                               Foreground="{StaticResource FgBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding FolderRemaining}"
                               Foreground="{StaticResource GreenBrush}" FontSize="11" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
            <ProgressBar Height="8" Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"
                         Foreground="{StaticResource GreenBrush}" Background="{StaticResource BgTertiaryBrush}"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding Status}" Foreground="{StaticResource FgSecondaryBrush}"
                   FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <Grid Grid.Row="4"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource FgBrush}"
                    BorderThickness="0" Padding="14,8" Cursor="Hand" Margin="0,0,8,0" FontSize="13"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
            <Button Content="Download &amp; Install" Style="{StaticResource PrimaryButton}" Padding="20,8" FontSize="13"
                    Command="{Binding DownloadCommand}"
                    Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
    </Grid>
</Window>
