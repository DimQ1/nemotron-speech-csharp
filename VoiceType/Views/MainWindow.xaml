<Window x:Class="VoiceType.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VoiceType.ViewModels"
        Title="VoiceType"
        Width="420" Height="520"
        MinWidth="320" MinHeight="360"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource BgBrush}" CornerRadius="12" BorderBrush="{StaticResource BgTertiaryBrush}" BorderThickness="1">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondaryBrush}" CornerRadius="12,12,0,0">
                <Grid Margin="14,0">
                    <TextBlock Text="🎙 VoiceType" Foreground="{StaticResource FgBrush}"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="📥" Style="{StaticResource IconButton}"
                                ToolTip="Download Models"
                                Command="{Binding OpenModelDownloaderCommand}"/>
                        <Button Content="⚙" Style="{StaticResource IconButton}"
                                ToolTip="Settings"
                                Command="{Binding OpenSettingsCommand}"/>
                        <Button Content="✕" Style="{StaticResource IconButton}"
                                Click="CloseButton_Click" ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="1" Background="{StaticResource BgSecondaryBrush}" Padding="14,8">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource FgSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource RedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FgSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding RecordingIndicator}" HorizontalAlignment="Right"
                               Foreground="{StaticResource FgSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Text area (selectable + copyable) -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="14,10">
                <TextBox x:Name="TextDisplay"
                         Text="{Binding FloatingText, Mode=OneWay}"
                         Foreground="{StaticResource FgBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         FontSize="15"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Disabled"
                         CaretBrush="{StaticResource FgBrush}"
                         ContextMenuOpening="TextDisplay_ContextMenuOpening">
                    <TextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="📋 Copy" Click="CopyMenuItem_Click"
                                      Foreground="{StaticResource FgBrush}"
                                      Background="{StaticResource BgSecondaryBrush}"/>
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>
            </ScrollViewer>

            <!-- Bottom controls -->
            <Border Grid.Row="3" Background="{StaticResource BgSecondaryBrush}"
                    CornerRadius="0,0,12,12" Padding="14,12">
                <StackPanel>
                    <Button Content="{Binding RecordButtonText}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ToggleCommand}"
                            HorizontalAlignment="Stretch" Height="42"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Text="Ctrl+Shift+V to toggle • Any key/mouse stops"/>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      Content="Enable text injection"
                                      IsChecked="{Binding IsTextInjectionEnabled}"
                                      Style="{StaticResource DarkCheckBox}"
                                      VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
                                    Content="📋 Copy"
                                    Margin="12,0,0,0"
                                    Background="{StaticResource BgTertiaryBrush}"
                                    Foreground="{StaticResource FgBrush}"
                                    BorderThickness="0"
                                    Padding="10,4"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Command="{Binding CopyCommand}"
                                    CommandParameter="{Binding ElementName=TextDisplay}"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
